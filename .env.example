# =============================================================================
# FinText-LLM environment configuration
# =============================================================================
# Copy this file to .env (or source it) before running any LLM-backed
# command. The repository does not commit real API keys; the placeholders
# below are intentional so the v16 demo works out of the box.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider selection
# -----------------------------------------------------------------------------
# ``sglang`` (default) talks to a local GPU server.
# ``deepseek`` uses the DeepSeek public API (OpenAI-compatible).
# ``openai`` / ``claude`` / ``gemini`` follow the same shape via the
# openai-compatible base_url.
LLM_PROVIDER=deepseek

# -----------------------------------------------------------------------------
# DeepSeek configuration (https://api-docs.deepseek.com)
# -----------------------------------------------------------------------------
# Base URL for the DeepSeek public API. The OpenAI-compatible endpoint is
# ``https://api.deepseek.com``; the Anthropic-compatible endpoint is
# ``https://api.deepseek.com/anthropic`` and is not used by the v1 client.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Default chat model. As of 2026-06 the recommended non-reasoning model is
# ``deepseek-chat`` (maps to deepseek-v4-flash). ``deepseek-reasoner`` is
# available for chain-of-thought workloads. Both aliases are scheduled to be
# deprecated on 2026-07-24; use ``deepseek-v4-pro`` or ``deepseek-v4-flash``
# directly afterwards.
DEEPSEEK_MODEL=deepseek-chat

# Bearer token for DeepSeek. Apply at https://platform.deepseek.com.
# Replace the placeholder with your real key; the literal string below
# is rejected by the API so accidental commits do not silently leak
# production traffic.
DEEPSEEK_API_KEY=REPLACE_ME

# Optional knobs. Leave commented out to use the client defaults.
# DEEPSEEK_TEMPERATURE=0.1
# DEEPSEEK_MAX_TOKENS=2000
# DEEPSEEK_TIMEOUT_S=60

# -----------------------------------------------------------------------------
# Local LLM (sglang / vLLM) — kept for the offline demo
# -----------------------------------------------------------------------------
# The default FinRisk demo uses a cached fixture, so these are not
# required for the v15/v16 demos but are useful for live runs.
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_MODEL=Qwen/Qwen3.5-35B-A3B
SGLANG_API_KEY=EMPTY

VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3.5-35B-A3B
VLLM_API_KEY=dummy

# -----------------------------------------------------------------------------
# OpenAI-compatible fallback (used by EdgarLLMClient when LLM_PROVIDER=openai)
# -----------------------------------------------------------------------------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Generic LLM_MODEL knob consumed by ``src.config.Settings``. Defaults to
# whatever the active provider configures; you usually do not need to set it.
# LLM_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# API safety and run persistence
# -----------------------------------------------------------------------------
# Comma-separated API keys accepted by FastAPI routes via the X-API-Key header.
# Leave as REPLACE_ME until you run the API through HTTP; the app fails closed
# when auth is not configured. For direct local handler tests only, set
# AUTH_DISABLED=1 in your shell instead of committing it here.
FINRISK_API_KEYS=REPLACE_ME

# Process-local rate limit for HTTP routes. Set RATE_LIMIT_DISABLED=1 only for
# local tests that need to bypass the middleware.
RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=120

# Run-store backend. `memory` is fastest for demos/tests; `sqlite` persists
# FinRisk and supply-chain run states to RUN_STORE_DB.
RUN_STORE_BACKEND=memory
RUN_STORE_DB=.cache/fintext_llm/runs.sqlite3

# Keep private / loopback hosts blocked for web_fetch/browser tools. Set
# WEB_FETCH_ALLOW_PRIVATE=1 only for tests against local stub servers.
# WEB_FETCH_ALLOW_PRIVATE=1

# -----------------------------------------------------------------------------
# SEC EDGAR
# -----------------------------------------------------------------------------
# SEC EDGAR public APIs do not require an API key. They do require an
# identifying User-Agent such as `YourApp/0.1 your_email@example.com`.
# Keep the configured rate below SEC's 10 requests/second fair-access limit.
SEC_USER_AGENT="FinText-LLM contact@example.com"
SEC_RATE_LIMIT_PER_SECOND=8.0

# -----------------------------------------------------------------------------
# Defeatbeta (free transcript + filing-catalog + ratios provider)
#
# Defeatbeta-api requires NO API key — it reads a public HuggingFace parquet
# mirror via DuckDB + cache_httpfs. The only optional knob is an HTTP proxy
# for restricted networks. Leave DEFEATBETA_PROXY commented out for direct
# access. Note: defeatingbeta's revenue-by-segment queries are broken in
# 0.0.48 (binder error) and its `wacc()` method is also broken in that
# release; the adapter degrades gracefully and returns empty/None for
# those calls. See ``src/data/providers/defeatbeta.py`` for details.
# -----------------------------------------------------------------------------
# DEFEATBETA_PROXY=http://proxy.example.com:8080

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME

# LLM-visible graph tools return `graph_source=unavailable` when no graph
# backend is injected. Set this only for local demo/fixture tests that should
# expose the bundled AAPL/TSMC example graph to the LLM.
GRAPH_TOOL_ALLOW_FIXTURE=0

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
CACHE_DIR=.cache/fintext_llm

# -----------------------------------------------------------------------------
# SearchRouter providers
#
# Provider names: duckduckgo, brave, tavily.
# Tavily and Brave are skipped automatically when their API key is missing.
# Keep API keys blank unless you want live web-search traffic.
# -----------------------------------------------------------------------------
SEARCH_PROVIDER_ORDER=duckduckgo

# Recommended live-search order once keys are configured:
# SEARCH_PROVIDER_ORDER=tavily,brave,duckduckgo

# Tavily Search API key. Apply at https://app.tavily.com/.
# Leave blank to skip Tavily and fall back to the next provider.
# TAVILY_API_KEY=tvly-...
TAVILY_API_KEY=

# Brave Search API key. Apply at https://api.search.brave.com/.
# Leave blank to skip Brave and fall back to the next provider.
BRAVE_API_KEY=
# Alias supported by official Brave examples; either Brave key variable works.
BRAVE_SEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Browser exploration backend
#
# `playwright` is the default maintained backend for browser_explore.
# `agent-browser` remains available as a legacy fallback if you have the CLI
# installed and want to compare behavior.
#
# First-time Playwright setup:
#   uv run playwright install chromium
# -----------------------------------------------------------------------------
BROWSER_BACKEND=playwright
